# 무료 실시간/근실시간 데이터 API 키
# 1) Finnhub (실시간 주식/FX)
VITE_FINNHUB_API_KEY=

# 2) Alpha Vantage (무료 fallback: GLOBAL_QUOTE, FX)
VITE_ALPHA_VANTAGE_API_KEY=

# 3) KIS Open API 프록시 (국내 지수 실시간)
# 프론트에 App Secret을 두면 안되므로 백엔드 프록시 URL만 사용
VITE_KIS_PROXY_BASE_URL=

# ---- KIS 프록시 서버용(서버 프로세스 환경변수) ----
KIS_PROXY_PORT=8787
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_TOKEN_PATH=/oauth2/tokenP
KIS_INDEX_PATH=/uapi/domestic-stock/v1/quotations/inquire-index-price
# 계정/상품군에 따라 TR_ID, ISCD 코드가 다를 수 있어 필요시 수정
KIS_TR_ID=FHPUP02110000
KIS_KOSPI_CODE=0001
KIS_KOSDAQ_CODE=1001
